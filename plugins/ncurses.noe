plugin Ncurses {
    library "libncurses.so.6", "libncursesw.so.6", "libncurses.so", "libncursesw.so"
    bind initscr() -> pointer
    bind endwin() -> int
    bind cbreak() -> int
    bind noecho() -> int
    bind curs_set(int) -> int
    bind clear() -> int
    bind refresh() -> int
    bind timeout(int) -> void
    bind getch() -> int
    bind napms(int) -> int
    bind mvaddstr(int, int, string) -> int
}
